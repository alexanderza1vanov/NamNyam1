<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.namnyam.ui.splash.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splashFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splashFragment_to_clientHomeFragment"
            app:destination="@id/clientHomeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splashFragment_to_ownerHomeFragment"
            app:destination="@id/ownerHomeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splashFragment_to_courierHomeFragment"
            app:destination="@id/courierHomeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.namnyam.ui.auth.login.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_client_home"
            app:destination="@id/clientHomeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_owner_home"
            app:destination="@id/ownerHomeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_courier_home"
            app:destination="@id/courierHomeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.namnyam.ui.auth.register.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_register_to_client_home"
            app:destination="@id/clientHomeFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_register_to_owner_home"
            app:destination="@id/ownerHomeFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_register_to_courier_home"
            app:destination="@id/courierHomeFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/clientHomeFragment"
        android:name="com.example.namnyam.ui.client.ClientHomeFragment"
        android:label="ClientHome">
        <action
            android:id="@+id/action_clientHomeFragment_to_restaurantDetailsFragment"
            app:destination="@id/restaurantDetailsFragment" />

        <action
            android:id="@+id/action_clientHomeFragment_to_cartFragment"
            app:destination="@id/cartFragment" />
    </fragment>

    <fragment
        android:id="@+id/restaurantDetailsFragment"
        android:name="com.example.namnyam.ui.client.RestaurantDetailsFragment"
        android:label="RestaurantDetails">


        <action
            android:id="@+id/action_restaurantDetailsFragment_to_cartFragment"
            app:destination="@id/cartFragment" />
    </fragment>

    <fragment
        android:id="@+id/cartFragment"
        android:name="com.example.namnyam.ui.cart.CartFragment"
        android:label="Cart" />
        <action
            android:id="@+id/action_cartFragment_to_checkoutFragment"
            app:destination="@id/checkoutFragment" />

    <fragment
        android:id="@+id/ownerHomeFragment"
        android:name="com.example.namnyam.ui.owner.OwnerHomeFragment"
        android:label="OwnerHome">

        <action
            android:id="@+id/action_ownerHomeFragment_to_createRestaurantFragment"
            app:destination="@id/createRestaurantFragment" />
        <action
            android:id="@+id/action_ownerHomeFragment_to_editRestaurantFragment"
            app:destination="@id/editRestaurantFragment" />

        <action
            android:id="@+id/action_ownerHomeFragment_to_ownerProductsFragment"
            app:destination="@id/ownerProductsFragment" />
    </fragment>

    <fragment
        android:id="@+id/createRestaurantFragment"
        android:name="com.example.namnyam.ui.owner.CreateRestaurantFragment"
        android:label="CreateRestaurantFragment" />
    <fragment
        android:id="@+id/addressesFragment"
        android:name="com.example.namnyam.ui.client.AddressesFragment"
        android:label="AddressesFragment">
        <action
            android:id="@+id/action_addressesFragment_to_addAddressFragment"
            app:destination="@id/addAddressFragment" />
    </fragment>

    <fragment
        android:id="@+id/addAddressFragment"
        android:name="com.example.namnyam.ui.client.AddAddressFragment"
        android:label="AddAddressFragment" />
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.namnyam.ui.client.ProfileFragment"
        android:label="ProfileFragment" />
    <fragment
        android:id="@+id/courierHomeFragment"
        android:name="com.example.namnyam.ui.courier.CourierHomeFragment"
        android:label="CourierHome" />
    <fragment
        android:id="@+id/orderDetailsFragment"
        android:name="com.example.namnyam.ui.client.OrderDetailsFragment"
        android:label="OrderDetailsFragment" />
    <fragment
        android:id="@+id/ordersHistoryFragment"
        android:name="com.example.namnyam.ui.client.OrdersHistoryFragment"
        android:label="OrdersHistoryFragment">
        <action
            android:id="@+id/action_ordersHistoryFragment_to_orderDetailsFragment"
            app:destination="@id/orderDetailsFragment" />
    </fragment>
    <fragment
        android:id="@+id/checkoutFragment"
        android:name="com.example.namnyam.ui.checkout.CheckoutFragment"
        android:label="CheckoutFragment">
        <action
            android:id="@+id/action_checkoutFragment_to_orderDetailsFragment"
            app:destination="@id/orderDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/editProductFragment"
        android:name="com.example.namnyam.ui.owner.EditProductFragment"
        android:label="EditProductFragment">
        <argument
            android:name="productId"
            app:argType="long"
            android:defaultValue="-1" />
    </fragment>

    <action
        android:id="@+id/action_ownerHomeFragment_to_ownerProductsFragment"
        app:destination="@id/ownerProductsFragment" />

    <action
        android:id="@+id/action_ownerHomeFragment_to_editRestaurantFragment"
        app:destination="@id/editRestaurantFragment" />

    <fragment
        android:id="@+id/ownerProductsFragment"
        android:name="com.example.namnyam.ui.owner.OwnerProductsFragment"
        android:label="OwnerProductsFragment">
        <action
            android:id="@+id/action_ownerProductsFragment_to_editProductFragment"
            app:destination="@id/editProductFragment" />
    </fragment>


    <fragment
        android:id="@+id/editRestaurantFragment"
        android:name="com.example.namnyam.ui.owner.EditRestaurantFragment"
        android:label="EditRestaurantFragment" />

</navigation>