<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.namnyam.ui.splash.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splashFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splashFragment_to_clientHomeFragment"
            app:destination="@id/clientHomeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splashFragment_to_ownerHomeFragment"
            app:destination="@id/ownerHomeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splashFragment_to_courierHomeFragment"
            app:destination="@id/courierHomeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.namnyam.ui.auth.login.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_client_home"
            app:destination="@id/clientHomeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_owner_home"
            app:destination="@id/ownerHomeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_courier_home"
            app:destination="@id/courierHomeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.namnyam.ui.auth.register.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_register_to_client_home"
            app:destination="@id/clientHomeFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_register_to_owner_home"
            app:destination="@id/ownerHomeFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_register_to_courier_home"
            app:destination="@id/courierHomeFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/clientHomeFragment"
        android:name="com.example.namnyam.ui.client.ClientHomeFragment"
        android:label="ClientHome">
        <action
            android:id="@+id/action_clientHomeFragment_to_restaurantDetailsFragment"
            app:destination="@id/restaurantDetailsFragment" />

        <action
            android:id="@+id/action_clientHomeFragment_to_cartFragment"
            app:destination="@id/cartFragment" />
    </fragment>

    <fragment
        android:id="@+id/restaurantDetailsFragment"
        android:name="com.example.namnyam.ui.client.RestaurantDetailsFragment"
        android:label="RestaurantDetails">

        <action
            android:id="@+id/action_restaurantDetailsFragment_to_cartFragment"
            app:destination="@id/cartFragment" />
    </fragment>

    <fragment
        android:id="@+id/cartFragment"
        android:name="com.example.namnyam.ui.cart.CartFragment"
        android:label="Cart" />

    <fragment
        android:id="@+id/ownerHomeFragment"
        android:name="com.example.namnyam.ui.owner.OwnerHomeFragment"
        android:label="OwnerHome" />

    <fragment
        android:id="@+id/courierHomeFragment"
        android:name="com.example.namnyam.ui.courier.CourierHomeFragment"
        android:label="CourierHome" />
</navigation>